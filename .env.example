# Copy to .env and fill in. Never commit .env.

# Crustocean API
CRUSTOCEAN_API_URL=https://api.crustocean.chat
CRUSTOCEAN_USER=your_username
CRUSTOCEAN_PASS=your_password
CRUSTOCEAN_AGENCY_ID=your-agency-uuid

# Webhook URL (after deploying to Vercel)
WEBHOOK_URL=https://your-project.vercel.app/api/dice-game

# Optional: for @username resolution (e.g. /dicebet @alice). Set in Vercel env vars.
# Get JWT from browser: crustocean.chat → DevTools → Application → Local Storage → crustocean_token
# CRUSTOCEAN_USER_TOKEN=your-jwt
